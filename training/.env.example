# Copy to .env and adjust (docker compose reads .env automatically).
# Chameleon: tracking server on same VM as Docker → host networking + 127.0.0.1
# Used by both tone-train and llm-train services.
MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# Optional: passed as Docker build-arg (also set in shell: export GIT_SHA=$(git rev-parse HEAD))
# GIT_SHA=unknown
